# Streamlit Cloud Secrets
# Copy these values into the Streamlit Cloud dashboard → App settings → Secrets
#
# This deployment serves TWO dashboards:
#   1. Analytics  (pages/1_acquisition.py ... pages/6_marketing.py)
#      → uses SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY (single env, Prod by convention)
#   2. Admin      (pages/7_Account_Deletion.py ... pages/10_Messaging_TestSend.py)
#      → uses QA_SUPABASE_* and PROD_SUPABASE_* (sidebar env selector)
#
# Both can coexist — just set all of them below.

# --- Analytics (read-only, Prod data) -------------------------------------
SUPABASE_URL = "https://rmccpzrnzfzwvqwlobuv.supabase.co"
SUPABASE_SERVICE_ROLE_KEY = "eyJ..."

# --- Admin dashboard — QA environment --------------------------------------
QA_SUPABASE_URL = "https://hgtbhaykvamhqccbyqww.supabase.co"
QA_SUPABASE_SERVICE_ROLE_KEY = "eyJ..."

# --- Admin dashboard — Prod environment ------------------------------------
PROD_SUPABASE_URL = "https://rmccpzrnzfzwvqwlobuv.supabase.co"
PROD_SUPABASE_SERVICE_ROLE_KEY = "eyJ..."

# --- RevenueCat (optional — only needed if Account Deletion page uses it) --
